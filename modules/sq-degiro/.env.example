# sq-degiro LIVE flavour credentials — copy to `.env` (same folder) and fill in.
# `.env` is gitignored; it stays local and never leaves your machine.

DEGIRO_USERNAME=your_degiro_username
DEGIRO_PASSWORD=your_degiro_password

# Only if 2FA is enabled on your Degiro account.
# This is the 32-character "setup key" Degiro shows (as text, next to the QR code)
# when you ENABLE 2FA. If you only have the authenticator app and not this key,
# you can re-enable 2FA on Degiro to reveal it, then copy it here.
DEGIRO_TOTP_SECRET=your_32_char_2fa_setup_key
