#!/usr/bin/env bash
# sq-degiro convenience wrapper — one short command per bundle entry point.
# Always uses the project's venv python so dependencies resolve correctly.
set -e
ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
PY="$ROOT/.venv/bin/python"
[ -x "$PY" ] || PY="python3"   # CI / no-venv fallback
case "${1:-}" in
  --describe) echo "Degiro broker — CSV history + live positions"; exit 0 ;;
  --kind) echo "broker"; exit 0 ;;
  --commands)
    # tab-separated name<TAB>description; consumed by the sciqnt dispatcher.
    # `doctor` with no subcommand is the read-only per-account health check;
    # probe / fix-totp underneath it are the deeper login diagnostics.
    printf "setup\tStore credentials (keychain or .env fallback, verified)\n"
    printf "live\tFetch current positions + cash (one account; picker when several)\t[--account NAME]\n"
    printf "sync\tRefresh history CSVs from Degiro — every configured account, or one\t[--account NAME]\n"
    printf "forget\tRemove a connected account (credentials + session)\t[--account NAME]\n"
    printf "doctor\tHealth check per account: creds · session · history CSVs\t[probe|fix-totp]\n"
    exit 0
    ;;
  setup)    shift; exec "$PY" "$ROOT/modules/sq-degiro/setup_creds.py" "$@" ;;
  forget)   shift; exec "$PY" "$ROOT/modules/sq-degiro/forget_creds.py" "$@" ;;
  live)     shift; exec "$PY" "$ROOT/modules/sq-degiro/src/sq_degiro/live.py" "$@" ;;
  sync)     shift; exec "$PY" "$ROOT/modules/sq-degiro/src/sq_degiro/history_sync.py" "$@" ;;
  doctor)
    shift
    case "${1:-}" in
      "")         exec "$PY" "$ROOT/modules/sq-degiro/doctor.py" ;;
      help|-h|--help)
        cat <<USAGE
sq-degiro doctor — health check + login diagnostics
  (no args)    Read-only health check per configured account:
               credentials · persisted session · history CSV freshness
  probe        Diagnose login WITHOUT storing — isolates password vs TOTP key
  fix-totp     Diagnose / normalize stored TOTP setup key
  show-creds   Print stored username + TOTP setup key (⚠ secrets to terminal)
USAGE
        exit 0
        ;;
      probe)      shift; exec "$PY" "$ROOT/modules/sq-degiro/probe.py" "$@" ;;
      fix-totp)   shift; exec "$PY" "$ROOT/modules/sq-degiro/fix_totp.py" "$@" ;;
      show-creds) shift; exec "$PY" "$ROOT/modules/sq-degiro/show_creds.py" "$@" ;;
      *) echo "unknown doctor command: $1 (try: probe | fix-totp | show-creds, or no args for the health check)" >&2; exit 1 ;;
    esac
    ;;
  # Back-compat: keep the direct commands working so existing muscle memory
  # / scripts don't break, but they're not advertised in --commands anymore.
  probe)    shift; exec "$PY" "$ROOT/modules/sq-degiro/probe.py" "$@" ;;
  fix-totp) shift; exec "$PY" "$ROOT/modules/sq-degiro/fix_totp.py" "$@" ;;
  *) echo "usage: $(basename "$0") {setup|live [--account NAME]|sync [--account NAME]|forget [--account NAME]|doctor [probe|fix-totp|show-creds]} [args]" >&2; exit 1 ;;
esac
