#!/usr/bin/env bash
# sq-edgar convenience wrapper — SEC filings + fundamentals (no key).
set -e
BUNDLE="$(cd "$(dirname "$0")/.." && pwd)"
ROOT="$(cd "$BUNDLE/../.." && pwd)"
PY="$ROOT/.venv/bin/python"
[ -x "$PY" ] || PY="$(command -v python3)"
case "${1:-}" in
  --describe) echo "SEC EDGAR — fundamentals + filings (8-K, Form 4, 10-K/Q) for US-listed companies (official, no key)"; exit 0 ;;
  --kind) echo "filings"; exit 0 ;;
  --commands)
    printf "company\tFundamentals + recent filings for ticker(s)\t<ticker> [ticker ...]\n"
    exit 0
    ;;
  company) shift; exec "$PY" "$BUNDLE/src/sq_edgar/edgar.py" "$@" ;;
  *) echo "usage: $(basename "$0") company <ticker> [ticker ...]" >&2; exit 1 ;;
esac
