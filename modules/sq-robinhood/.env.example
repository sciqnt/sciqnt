# sq-robinhood LIVE flavour credentials — copy to `.env` (same folder) and fill in.
# Preferred path is the OS keychain via `sciqnt robinhood setup`; this .env is the
# fallback when the keychain is unavailable (e.g. macOS over SSH). 0600, gitignored.
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
# Base32 MFA/2FA setup key (if you use an authenticator app). Blank for SMS/none.
ROBINHOOD_MFA_SECRET=
