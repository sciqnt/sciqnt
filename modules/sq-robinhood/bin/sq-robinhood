#!/usr/bin/env bash
# sq-robinhood convenience wrapper — one short command per bundle entry point.
# Always uses the project's venv python so dependencies resolve correctly.
set -e
ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
PY="$ROOT/.venv/bin/python"
[ -x "$PY" ] || { echo "no venv at $PY — create with: python3 -m venv $ROOT/.venv" >&2; exit 1; }
case "${1:-}" in
  --describe) echo "Robinhood broker — live positions + cash (unofficial, robin_stocks)"; exit 0 ;;
  --kind) echo "broker,crypto"; exit 0 ;;
  --commands)
    # tab-separated name<TAB>description; consumed by the sciqnt dispatcher
    printf "setup\tStore credentials (keychain or .env fallback, verified)\n"
    printf "live\tFetch current positions + cash\n"
    exit 0
    ;;
  setup) shift; exec "$PY" "$ROOT/modules/sq-robinhood/setup_creds.py" "$@" ;;
  live)  shift; exec "$PY" "$ROOT/modules/sq-robinhood/src/sq_robinhood/live.py" "$@" ;;
  *) echo "usage: $(basename "$0") {setup|live} [args]" >&2; exit 1 ;;
esac
