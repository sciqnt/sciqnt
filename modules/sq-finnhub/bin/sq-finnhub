#!/usr/bin/env bash
# sq-finnhub convenience wrapper — official company news (free key).
set -e
BUNDLE="$(cd "$(dirname "$0")/.." && pwd)"
ROOT="$(cd "$BUNDLE/../.." && pwd)"
PY="$ROOT/.venv/bin/python"
[ -x "$PY" ] || PY="$(command -v python3)"
case "${1:-}" in
  --describe) echo "Finnhub — official company news for a ticker (free key, news-chain rung)"; exit 0 ;;
  --kind) echo "news"; exit 0 ;;
  --commands)
    printf "auth\tStore your free Finnhub API key (verified before saving)\n"
    printf "news\tLatest company news for ticker(s)\t<ticker> [ticker ...]\n"
    exit 0
    ;;
  auth) shift; exec "$PY" "$BUNDLE/setup_auth.py" "$@" ;;
  news) shift; exec "$PY" "$BUNDLE/src/sq_finnhub/news.py" "$@" ;;
  *) echo "usage: $(basename "$0") {auth|news <ticker> [ticker ...]}" >&2; exit 1 ;;
esac
