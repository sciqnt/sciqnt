#!/usr/bin/env bash
# sq-firds convenience wrapper — ISIN → EU regulatory reference data.
set -e
BUNDLE="$(cd "$(dirname "$0")/.." && pwd)"
ROOT="$(cd "$BUNDLE/../.." && pwd)"
PY="$ROOT/.venv/bin/python"
[ -x "$PY" ] || PY="$(command -v python3)"
case "${1:-}" in
  --describe) echo "ESMA FIRDS — ISIN to official EU reference data: name, CFI, asset class, currency (no key)"; exit 0 ;;
  --kind) echo "reference"; exit 0 ;;
  --commands)
    printf "resolve\tResolve ISIN(s) to reference data\t<isin> [isin ...]\n"
    exit 0
    ;;
  resolve) shift; exec "$PY" "$BUNDLE/src/sq_firds/resolve.py" "$@" ;;
  *) echo "usage: $(basename "$0") resolve <isin> [isin ...]" >&2; exit 1 ;;
esac
