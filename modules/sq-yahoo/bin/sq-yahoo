#!/usr/bin/env bash
# sq-yahoo convenience wrapper — quotes + daily closes from Yahoo's chart API.
set -e
BUNDLE="$(cd "$(dirname "$0")/.." && pwd)"
ROOT="$(cd "$BUNDLE/../.." && pwd)"
PY="$ROOT/.venv/bin/python"
[ -x "$PY" ] || PY="$(command -v python3)"
case "${1:-}" in
  --describe) echo "Yahoo Finance — live quotes + historical daily closes (price overlay source)"; exit 0 ;;
  --kind) echo "pricing,fx"; exit 0 ;;
  --commands)
    printf "quote\tFetch a live quote\t<ticker>\n"
    printf "close\tClosing price on/before a date\t<ticker> <YYYY-MM-DD>\n"
    printf "history\tFull daily history summary (+ div/split counts)\t<ticker>\n"
    exit 0
    ;;
  quote|close|history) exec "$PY" "$BUNDLE/src/sq_yahoo/cli.py" "$@" ;;
  *) echo "usage: $(basename "$0") {quote <ticker>|close <ticker> <date>|history <ticker>}" >&2; exit 1 ;;
esac
