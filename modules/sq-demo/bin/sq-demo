#!/usr/bin/env bash
# sq-demo wrapper — platform contract: --describe / --kind / --commands.
ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
PY="$ROOT/.venv/bin/python"
[ -x "$PY" ] || PY="python3"
case "${1:-}" in
  --describe) echo "deterministic demo portfolio — sciqnt's public figures (synthetic, offline)";;
  --kind)     echo "demo";;
  --commands) printf "show\tprint the demo snapshot (same as the app's first-run view)\n";;
  show)
    PYTHONPATH="$ROOT/core:$ROOT/modules/sq-demo/src${PYTHONPATH:+:$PYTHONPATH}" \
      exec "$PY" -c "import sq_demo; s = sq_demo.snapshot(); print(f'{s.account.display_name}: {len(s.positions)} positions, cash {s.cash_balances[0].amount} EUR')";;
  *) echo "usage: sq-demo [--describe|--kind|--commands|show]" >&2; exit 2;;
esac
